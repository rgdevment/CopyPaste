<Project Sdk="Microsoft.NET.Sdk">
<PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows10.0.22621.0</TargetFramework>
    <TargetPlatformMinVersion>10.0.19041.0</TargetPlatformMinVersion>
    <RootNamespace>CopyPaste.UI</RootNamespace>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationIcon>Assets\CopyPasteLogoSimple.ico</ApplicationIcon>
    <Platforms>x64</Platforms>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <UseWinUI>true</UseWinUI>
    <Nullable>enable</Nullable>
    <LangVersion>preview</LangVersion>

    <AssemblyName>CopyPaste</AssemblyName>

    <!-- WinUI unpackaged app configuration -->
    <WindowsPackageType>None</WindowsPackageType>
    <WindowsAppSDKSelfContained>true</WindowsAppSDKSelfContained>
    <WinUISDKReferences>true</WinUISDKReferences>

    <!-- Self-contained deployment (NO trimming - WinUI not compatible) -->
    <SelfContained>true</SelfContained>
    <PublishSelfContained>true</PublishSelfContained>
    
    <!-- Only English - no other languages needed -->
    <SatelliteResourceLanguages>en</SatelliteResourceLanguages>
    
    <!-- Exclude Windows App SDK language folders -->
    <WindowsAppSDKSelfContainedExcludeLanguages>true</WindowsAppSDKSelfContainedExcludeLanguages>
    
    <!-- Exclude debug symbols from publish -->
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>

    <NoWarn>$(NoWarn);CA1515;CA5392</NoWarn>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
</PropertyGroup>

    <ItemGroup>
        <Page Remove="Controls\ClipboardItemCard.xaml" />
    </ItemGroup>

    <ItemGroup>
        <Manifest Include="$(ApplicationManifest)" />
    </ItemGroup>
    
    <!-- Include ALL assets and copy to output -->
    <ItemGroup>
        <Content Include="Assets\**\*">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </Content>
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
        <PackageReference Include="H.NotifyIcon.WinUI" Version="2.4.1" />
        <PackageReference Include="Microsoft.Windows.SDK.BuildTools" Version="10.0.26100.7463" />
        <PackageReference Include="Microsoft.WindowsAppSDK" Version="1.8.260101001" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\CopyPaste.Core\CopyPaste.Core.csproj" />
        <ProjectReference Include="..\CopyPaste.Listener\CopyPaste.Listener.csproj" />
    </ItemGroup>

    <ItemGroup>
        <None Update="Controls\ClipboardItemCard.xaml">
            <Generator>MSBuild:Compile</Generator>
        </None>
    </ItemGroup>
</Project>
