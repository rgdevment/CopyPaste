<Project Sdk="Microsoft.NET.Sdk">
<PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows10.0.22621.0</TargetFramework>
    <TargetPlatformMinVersion>10.0.19041.0</TargetPlatformMinVersion>
    <RootNamespace>CopyPaste.UI</RootNamespace>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationIcon>Assets\CopyPasteLogoSimple.ico</ApplicationIcon>
    <Platforms>x64</Platforms>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <UseWinUI>true</UseWinUI>
    <Nullable>enable</Nullable>
    <LangVersion>preview</LangVersion>

    <AssemblyName>CopyPaste</AssemblyName>

    <WindowsPackageType>None</WindowsPackageType>
    <WindowsAppSDKSelfContained>true</WindowsAppSDKSelfContained>
    <WinUISDKReferences>true</WinUISDKReferences>
    
    <!-- Force include bootstrapper for unpackaged apps -->
    <WindowsAppSDKBootstrapInitialize>true</WindowsAppSDKBootstrapInitialize>

    <!-- Self-contained and AOT -->
    <SelfContained>true</SelfContained>
    <PublishSelfContained>true</PublishSelfContained>
    <PublishAot>true</PublishAot>
    <PublishReadyToRun>false</PublishReadyToRun>

    <!-- AOT Optimizations - WinUI compatible -->
    <IlcOptimizationPreference>Speed</IlcOptimizationPreference>
    <TrimMode>link</TrimMode>
    <InvariantGlobalization>false</InvariantGlobalization>
    <StackTraceSupport>true</StackTraceSupport>

    <!-- Exclude unnecessary satellite assemblies from our code -->
    <SatelliteResourceLanguages>en</SatelliteResourceLanguages>
    
    <!-- Exclude Windows App SDK language folders -->
    <WindowsAppSDKSelfContainedExcludeLanguages>true</WindowsAppSDKSelfContainedExcludeLanguages>

    <NoWarn>$(NoWarn);CA1515;CA5392</NoWarn>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
        
    <!-- Enable COM interop for Native AOT -->
    <BuiltInComInteropSupport>true</BuiltInComInteropSupport>
</PropertyGroup>

    <ItemGroup>
        <Content Remove="Assets\CopyPasteLogoSimple.ico" />
        <Content Remove="Assets\CopyPasteNotification.ico" />
    </ItemGroup>
    <ItemGroup>
        <None Remove="Assets\CopyPasteLogo.ico" />
    </ItemGroup>
    <ItemGroup>
        <Page Remove="Controls\ClipboardItemCard.xaml" />
    </ItemGroup>

    <ItemGroup>
        <Manifest Include="$(ApplicationManifest)" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
        <PackageReference Include="H.NotifyIcon.WinUI" Version="2.4.1" />
        <PackageReference Include="Microsoft.Windows.SDK.BuildTools" Version="10.0.26100.7463" />
        <PackageReference Include="Microsoft.WindowsAppSDK" Version="1.8.260101001" />
        <PackageReference Include="System.Formats.Nrbf" Version="10.0.0" />
    </ItemGroup>
    
    <ItemGroup>
        <!-- Prevent trimming of System.Formats.Nrbf for AOT compilation -->
        <TrimmerRootAssembly Include="System.Formats.Nrbf" />
        
        <!-- Include runtime directives for AOT -->
        <RdXmlFile Include="rd.xml" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\CopyPaste.Core\CopyPaste.Core.csproj" />
        <ProjectReference Include="..\CopyPaste.Listener\CopyPaste.Listener.csproj" />
    </ItemGroup>

    <ItemGroup>
        <Content Include="Assets\CopyPasteLogoSimple.ico">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </Content>
    </ItemGroup>

    <ItemGroup>
        <Content Update="Assets\CopyPasteLogo.ico">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </Content>
    </ItemGroup>

    <ItemGroup>
        <None Update="Controls\ClipboardItemCard.xaml">
            <Generator>MSBuild:Compile</Generator>
        </None>
    </ItemGroup>
</Project>
