<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
  <OutputType>WinExe</OutputType>
  <TargetFramework>net10.0-windows10.0.19041.0</TargetFramework>
  <TargetPlatformMinVersion>10.0.17763.0</TargetPlatformMinVersion>
  <RootNamespace>CopyPaste.UI</RootNamespace>
  <ApplicationManifest>app.manifest</ApplicationManifest>
  <ApplicationIcon>Assets\CopyPasteLogoSimple.ico</ApplicationIcon>
  <Platforms>x64</Platforms>
  <RuntimeIdentifier>win-x64</RuntimeIdentifier>
  <UseWinUI>true</UseWinUI>
  <Nullable>enable</Nullable>
  <LangVersion>preview</LangVersion>

    <WindowsPackageType>None</WindowsPackageType>
    <WindowsAppSDKSelfContained>true</WindowsAppSDKSelfContained>
    <WinUISDKReferences>true</WinUISDKReferences>

    <SelfContained>True</SelfContained>
    <PublishSelfContained>True</PublishSelfContained>
    <PublishReadyToRun>False</PublishReadyToRun>
    <PublishTrimmed>False</PublishTrimmed>

    <NoWarn>$(NoWarn);CA1515;CA5392</NoWarn>

    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>
  <ItemGroup>
    <Content Remove="Assets\CopyPasteLogoSimple.ico" />
    <Content Remove="Assets\CopyPasteNotification.ico" />
  </ItemGroup>
  <ItemGroup>
    <None Remove="Assets\CopyPasteLogo.ico" />
  </ItemGroup>
  <ItemGroup>
    <Page Remove="Controls\ClipboardItemCard.xaml" />
  </ItemGroup>

  <ItemGroup>
    <Manifest Include="$(ApplicationManifest)" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
    <PackageReference Include="H.NotifyIcon.WinUI" Version="2.4.1" />
    <PackageReference Include="Microsoft.Windows.SDK.BuildTools" Version="10.0.26100.7463" />
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="1.8.260101001" />
  </ItemGroup>

  <ItemGroup>
      <ProjectReference Include="..\CopyPaste.Core\CopyPaste.Core.csproj" />
      <ProjectReference Include="..\CopyPaste.Listener\CopyPaste.Listener.csproj" />
    </ItemGroup>

    <ItemGroup>
      <Content Include="Assets\CopyPasteLogoSimple.ico">
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      </Content>
    </ItemGroup>

    <ItemGroup>
      <Content Update="Assets\CopyPasteLogo.ico">
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      </Content>
    </ItemGroup>

    <ItemGroup>
      <None Update="Controls\ClipboardItemCard.xaml">
        <Generator>MSBuild:Compile</Generator>
      </None>
    </ItemGroup>
  </Project>
