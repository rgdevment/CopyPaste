<Window
    x:Class="CopyPaste.UI.WelcomeWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="CopyPaste">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="24">
            
            <Image Source="ms-appx:///Assets/CopyPasteLogo.png" 
                   Width="96" Height="96"
                   HorizontalAlignment="Center"/>
            
            <TextBlock Text="Welcome to CopyPaste" 
                       FontSize="28" 
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"/>
            
            <TextBlock Text="Setting up for first use..." 
                       FontSize="14" 
                       Opacity="0.7"
                       HorizontalAlignment="Center"/>
            
            <ProgressRing IsActive="True" 
                          Width="32" Height="32"
                          HorizontalAlignment="Center"/>
            
        </StackPanel>
    </Grid>
</Window>
