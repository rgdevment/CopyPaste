<Window
    x:Class="CopyPaste.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewmodels="using:CopyPaste.UI.ViewModels"
    xmlns:tb="using:H.NotifyIcon">

    <Window.SystemBackdrop>
        <DesktopAcrylicBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <tb:TaskbarIcon x:Name="TrayIcon"
                        IconSource="/Assets/CopyPasteLogo.ico"
                        ToolTipText="CopyPaste"
                        DoubleClickCommand="{x:Bind ViewModel.ShowWindowCommand}"
                        MenuActivation="RightClick">
            <tb:TaskbarIcon.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem Text="Salir" Command="{x:Bind ViewModel.ExitCommand}"/>
                </MenuFlyout>
            </tb:TaskbarIcon.ContextFlyout>
        </tb:TaskbarIcon>

        <Grid Grid.Row="0" Margin="16,16,16,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="CopyPaste" 
                       Grid.Column="0"
                       FontFamily="Segoe UI"
                       FontSize="14" 
                       FontWeight="Normal" 
                       Opacity="0.8"
                       VerticalAlignment="Center"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">

                <Button Command="{x:Bind ViewModel.OpenRepoCommand}"
                        ToolTipService.ToolTip="Reportar error"
                        Padding="0"
                        Width="30" Height="30"
                        CornerRadius="4">
                    <FontIcon Glyph="&#xE8A7;" FontSize="12" Opacity="0.8"/>
                </Button>
            </StackPanel>
        </Grid>

        <ListView x:Name="ClipboardListView"
                  Grid.Row="1"
                  ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}"
                  SelectionMode="None"
                  Padding="4,0,4,12">

            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsStackPanel Orientation="Vertical"/>
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>

            <ListView.ItemTemplate>
                <DataTemplate x:DataType="viewmodels:ClipboardItemViewModel">

                    <Border MinHeight="80" 
                            CornerRadius="6"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            BorderThickness="1" 
                            BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
                            Margin="0,0,0,12"
                            PointerEntered="Card_PointerEntered"
                            PointerExited="Card_PointerExited">

                        <Grid Padding="16,12,16,16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Opacity="0.6">
                                    <FontIcon Glyph="{x:Bind TypeIcon}" FontSize="12" Margin="0,0,8,0"/>
                                    <TextBlock Text="{x:Bind HeaderTitle}" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock Text="•" Margin="6,0,6,0" FontSize="10"/>
                                    <TextBlock Text="{x:Bind Timestamp}" FontSize="11"/>
                                </StackPanel>
                            </Grid>








                            <TextBlock Text="{x:Bind Content}" 
                                       Grid.Row="1"
                                       MaxLines="3" 
                                       LineHeight="20"
                                       TextTrimming="CharacterEllipsis" 
                                       FontSize="13"
                                       Opacity="0.9"
                                       TextWrapping="Wrap"
                                       Visibility="{x:Bind IsTextVisible}"/>

                            <Image Source="{x:Bind Content}"
                                   Grid.Row="1"
                                   Stretch="UniformToFill"
                                   MaxHeight="140"
                                   HorizontalAlignment="Left"
                                   Visibility="{x:Bind ImageVisibility}"/>

                            <!-- Media (Video/Audio) Thumbnail with duration overlay -->
                            <Grid Grid.Row="1" Visibility="{x:Bind MediaThumbnailVisibility}">
                                <Image Source="{x:Bind ThumbnailPath, TargetNullValue=''}"
                                       Stretch="UniformToFill"
                                       MaxHeight="140"
                                       HorizontalAlignment="Left"/>
                                <Border Background="#AA000000" 
                                        CornerRadius="3" 
                                        Padding="4,2"
                                        HorizontalAlignment="Right" 
                                        VerticalAlignment="Bottom"
                                        Margin="0,0,4,4"
                                        Visibility="{x:Bind DurationVisibility}">
                                    <TextBlock Text="{x:Bind MediaDuration}" 
                                               FontSize="10" 
                                               Foreground="White"/>
                                </Border>
                            </Grid>

                            <StackPanel Orientation="Horizontal" 
                                        Grid.Row="2" 
                                        Margin="0,8,0,0"
                                        Visibility="{x:Bind FileWarningVisibility}">
                                <FontIcon Glyph="&#xE7BA;" FontSize="12" Foreground="#FFAA00" Margin="0,0,6,0"/>
                                <TextBlock Text="Archivo no disponible" FontSize="11" Foreground="#FFAA00" Opacity="0.9"/>
                            </StackPanel>

                            <!-- Footer: App Source (left) + Media Info (right) -->
                            <Grid Grid.Row="2" Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- App Source - Left -->
                                <StackPanel Grid.Column="0" 
                                            Orientation="Horizontal" 
                                            Visibility="{x:Bind AppSourceVisibility}"
                                            Opacity="0.5">
                                    <FontIcon Glyph="&#xE737;" FontSize="10" Margin="0,0,4,0"/>
                                    <TextBlock Text="{x:Bind AppSource}" FontSize="10" TextTrimming="CharacterEllipsis" MaxWidth="150"/>
                                </StackPanel>

                                <!-- Media Info (Duration + Dimensions + Size) - Right -->
                                <StackPanel Grid.Column="1" 
                                            Orientation="Horizontal" 
                                            Visibility="{x:Bind MediaInfoVisibility}"
                                            Opacity="0.5"
                                            Spacing="8">
                                    <StackPanel Orientation="Horizontal" Visibility="{x:Bind DurationVisibility}">
                                        <FontIcon Glyph="&#xE916;" FontSize="10" Margin="0,0,4,0"/>
                                        <TextBlock Text="{x:Bind MediaDuration}" FontSize="10"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Visibility="{x:Bind ImageDimensionsVisibility}">
                                        <FontIcon Glyph="&#xE799;" FontSize="10" Margin="0,0,4,0"/>
                                        <TextBlock Text="{x:Bind ImageDimensions}" FontSize="10"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Visibility="{x:Bind FileSizeVisibility}">
                                        <FontIcon Glyph="&#xE7C3;" FontSize="10" Margin="0,0,4,0"/>
                                        <TextBlock Text="{x:Bind FileSize}" FontSize="10"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <StackPanel x:Name="ActionPanel" 
                                        Grid.Row="0" Grid.RowSpan="2"
                                        Orientation="Horizontal" 
                                        HorizontalAlignment="Right" 
                                        VerticalAlignment="Top" 
                                        Margin="0,-4,-4,0"
                                        Spacing="2"
                                        Opacity="0">

                                <Button Width="26" Height="26" Padding="0" Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Opciones">
                                    <FontIcon Glyph="&#xE712;" FontSize="14"/>
                                    <Button.Flyout>
                                        <MenuFlyout Placement="BottomEdgeAlignedRight">
                                            <MenuFlyoutItem Text="Pegar" Icon="Paste" Command="{x:Bind PasteCommand}"/>
                                            <MenuFlyoutItem Text="Pegar sin formato" Command="{x:Bind PastePlainCommand}">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE75F;"/>
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                            <MenuFlyoutSeparator />
                                            <MenuFlyoutItem Text="{x:Bind PinMenuText, Mode=OneWay}" Command="{x:Bind TogglePinCommand}">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="{x:Bind PinIconGlyph, Mode=OneWay}"/>
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                        </MenuFlyout>
                                    </Button.Flyout>
                                </Button>

                                <Button Width="26" Height="26" Padding="0" Background="Transparent" BorderThickness="0" Command="{x:Bind DeleteCommand}" ToolTipService.ToolTip="Eliminar">
                                    <FontIcon Glyph="&#xE711;" FontSize="10"/>
                                </Button>
                            </StackPanel>

                            <FontIcon Glyph="&#xE840;" FontSize="12" 
                                      Grid.Row="1"
                                      HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                      Margin="0,0,-4,-4"
                                      Opacity="0.9"
                                      Foreground="{ThemeResource SystemControlHighlightAccentBrush}"
                                      Visibility="{x:Bind PinIndicatorVisibility, Mode=OneWay}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Window>
